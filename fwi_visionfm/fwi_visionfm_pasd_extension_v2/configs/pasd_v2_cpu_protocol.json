{
  "name": "pasd_v2_cpu_protocol",
  "scientific_protocol": {
    "source_family": "FlatVel-A",
    "target_family": "CurveVel-A",
    "fixed_manifest_required": true,
    "train_only_velocity_scaler": true,
    "seeds": [0, 1, 2],
    "primary_variants": ["B1_raw_unet", "B2_hybrid_unet", "B3_raw_bed", "B4_pasd_fwi"],
    "paired_bootstrap": {
      "baseline": "B1_raw_unet",
      "candidate": "B4_pasd_fwi",
      "resamples": 2000
    }
  },
  "bridge": {
    "raw": "robust percentile-clipped normalization",
    "envelope": "Hilbert amplitude envelope",
    "band": "lightweight temporal low/high-band energy",
    "geometry": "source coordinate, shot index, mean normalized offset"
  },
  "model": {
    "base_channels": 16,
    "latent_channels": 96,
    "latent_size": [9, 9],
    "full_method": "hybrid bridge + geometry attention + background-edge decoder"
  },
  "loss": {
    "background_sigma": 1.5,
    "edge_quantile": 0.8,
    "weight_l1": 1.0,
    "weight_background": 0.25,
    "weight_edge": 0.1,
    "weight_smooth": 0.02
  },
  "reporting": {
    "metrics": ["mae", "rmse", "ssim", "edge_mae", "gradient_error"],
    "common_sample_policy": "median MAE from B1 after strict sample_id alignment"
  }
}
