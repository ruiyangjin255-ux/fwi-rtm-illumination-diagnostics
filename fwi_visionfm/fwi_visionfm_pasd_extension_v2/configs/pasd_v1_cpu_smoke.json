{
  "name": "pasd_v1_cpu_smoke",
  "bridge": {
    "lowpass_kernel": 21,
    "band_low_weight": 0.5,
    "robust_clip_quantile": 0.995
  },
  "model": {
    "base_channels": 16,
    "latent_channels": 96,
    "latent_size": [9, 9],
    "aggregator": "geometry_attention",
    "residual_scale": 0.25
  },
  "loss": {
    "background_sigma": 1.5,
    "edge_quantile": 0.8,
    "weight_l1": 1.0,
    "weight_background": 0.25,
    "weight_edge": 0.1,
    "weight_smooth": 0.02
  },
  "training": {
    "seed": 0,
    "epochs": 3,
    "batch_size": 4,
    "learning_rate": 0.001,
    "weight_decay": 0.0001
  }
}
